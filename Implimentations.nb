          RowBox[{"(", 
           RowBox[{"1", "+", "n"}], ")"}], " ", 
          SuperscriptBox["z", "2"]}]}], ")"}]}]]}], 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"-", "1"}], "+", 
