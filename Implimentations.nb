Cell[CellGroupData[{

Cell["Change in AF", "Section",
 CellChangeTimes->{{3.972687715950233*^9, 
  3.97268771889428*^9}},ExpressionUUID->"a7c9f425-04d3-4697-84c0-\
c1cabc113d67"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"SS", "=", "5"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"params", "=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"Kp", "->", "K5"}], ",", 
    RowBox[{"n", "->", "SS"}], ",", 
    RowBox[{"sn", "->", "1"}], ",", 
    RowBox[{"kn", "->", 
     RowBox[{
      RowBox[{"Quantile", "[", 
       RowBox[{
        RowBox[{"NoncentralStudentTDistribution", "[", 
         RowBox[{
          RowBox[{"SS", "-", "1"}], ",", 
          RowBox[{
           RowBox[{"-", 
            RowBox[{"Sqrt", "[", "SS", "]"}]}], "K5"}]}], "]"}], ",", 
        "0.95"}], "]"}], "/", 
      RowBox[{"Sqrt", "[", "SS", "]"}]}]}], ",", "\[IndentingNewLine]", 
    RowBox[{"knn", "->", 
     RowBox[{
      RowBox[{"Quantile", "[", 
       RowBox[{
        RowBox[{"NoncentralStudentTDistribution", "[", 
         RowBox[{"SS", ",", 
          RowBox[{
           RowBox[{"-", 
            RowBox[{"Sqrt", "[", 
             RowBox[{"SS", "+", "1"}], "]"}]}], "K5"}]}], "]"}], ",", 
        "0.95"}], "]"}], "/", 
      RowBox[{"Sqrt", "[", 
       RowBox[{"SS", "+", "1"}], "]"}]}]}]}], 
   "}"}]}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"DAF", "[", 
     RowBox[{"x", ",", "SS", ",", "Kp", ",", "sn", ",", "kn", ",", "knn"}], 
     "]"}], "/.", "params"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{"-", "2"}], ",", "2"}], "}"}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"solX", "=", 
  RowBox[{"x", "/.", 
   RowBox[{"Solve", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"DAF", "[", 
       RowBox[{"x", ",", "n", ",", "Kp", ",", "sn", ",", "kn", ",", "knn"}], 
       "]"}], "==", "z"}], ",", "x"}], "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"minAF", "=", 
    RowBox[{"DAF", "[", 
     RowBox[{"0", ",", "n", ",", "Kp", ",", "sn", ",", "kn", ",", "knn"}], 
     "]"}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"Print", "[", "\"\<Probability that AF increases\>\"", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"intRng", "=", 
   RowBox[{
    RowBox[{"solX", "/.", "params"}], "/.", 
    RowBox[{"z", "->", "0"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"p", "=", 
  RowBox[{"1", "-", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"CDF", "[", 
      RowBox[{
       RowBox[{"StudentTDistribution", "[", 
        RowBox[{"SS", "-", "1"}], "]"}], ",", 
       RowBox[{"intRng", "[", 
        RowBox[{"[", "2", "]"}], "]"}]}], "]"}], "-", 
     RowBox[{"CDF", "[", 
      RowBox[{
       RowBox[{"StudentTDistribution", "[", 
        RowBox[{"SS", "-", "1"}], "]"}], ",", 
       RowBox[{"intRng", "[", 
        RowBox[{"[", "1", "]"}], "]"}]}], "]"}]}], ")"}]}]}]}], "Input",
 CellChangeTimes->{{3.972687773640566*^9, 3.97268789823612*^9}, {
