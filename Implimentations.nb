Cell[BoxData[{
 RowBox[{
  RowBox[{"params", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Kp", "->", "K5"}], ",", 
     RowBox[{"n", "->", "SS"}], ",", 
     RowBox[{"sn", "->", "1"}], ",", 
     RowBox[{"kn", "->", 
      RowBox[{
       RowBox[{"Quantile", "[", 
        RowBox[{
         RowBox[{"NoncentralStudentTDistribution", "[", 
          RowBox[{
           RowBox[{"SS", "-", "1"}], ",", 
           RowBox[{
            RowBox[{"-", 
             RowBox[{"Sqrt", "[", "SS", "]"}]}], "K5"}]}], "]"}], ",", 
         "0.95"}], "]"}], "/", 
       RowBox[{"Sqrt", "[", "SS", "]"}]}]}], ",", "\[IndentingNewLine]", 
     RowBox[{"knn", "->", 
      RowBox[{
       RowBox[{"Quantile", "[", 
        RowBox[{
         RowBox[{"NoncentralStudentTDistribution", "[", 
          RowBox[{"SS", ",", 
           RowBox[{
            RowBox[{"-", 
             RowBox[{"Sqrt", "[", 
              RowBox[{"SS", "+", "1"}], "]"}]}], "K5"}]}], "]"}], ",", 
         "0.95"}], "]"}], "/", 
       RowBox[{"Sqrt", "[", 
        RowBox[{"SS", "+", "1"}], "]"}]}]}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"solX", "=", 
   RowBox[{"x", "/.", 
    RowBox[{"Solve", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"DPNEC", "[", 
        RowBox[{"x", ",", "n", ",", "Kp", ",", "sn", ",", "kn", ",", "knn"}], 
        "]"}], "==", "z"}], ",", "x"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"maxX", "=", 
   RowBox[{"x", "/.", 
    RowBox[{"Simplify", "[", 
     RowBox[{
      RowBox[{"Solve", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"D", "[", 
          RowBox[{
           RowBox[{"DPNEC", "[", 
            RowBox[{
            "x", ",", "n", ",", "Kp", ",", "sn", ",", "kn", ",", "knn"}], 
            "]"}], ",", "x"}], "]"}], "==", "0"}], ",", "x"}], "]"}], "[", 
      RowBox[{"[", "2", "]"}], "]"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"maxPNEC", "=", 
   RowBox[{"DPNEC", "[", 
    RowBox[{"maxX", ",", "n", ",", "Kp", ",", "sn", ",", "kn", ",", "knn"}], 
    "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"maxZ", "=", 
  RowBox[{"maxPNEC", "/.", "params"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"del", "=", "0.01"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"znow", "=", 
   RowBox[{"-", "5"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"myCDF", "=", 
   RowBox[{"{", "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Do", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"intRng", "=", 
     RowBox[{
      RowBox[{"solX", "/.", "params"}], "/.", 
      RowBox[{"z", "->", "znow"}]}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"znow", ">", "maxZ"}], ",", 
      RowBox[{"Break", "[", "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"p", "=", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"CDF", "[", 
        RowBox[{
         RowBox[{"StudentTDistribution", "[", 
          RowBox[{"SS", "-", "1"}], "]"}], ",", 
         RowBox[{"intRng", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], "]"}], "-", 
       RowBox[{"CDF", "[", 
        RowBox[{
         RowBox[{"StudentTDistribution", "[", 
          RowBox[{"SS", "-", "1"}], "]"}], ",", 
         RowBox[{"intRng", "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], "]"}]}], ")"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"AppendTo", "[", 
     RowBox[{"myCDF", ",", 
      RowBox[{"{", 
       RowBox[{"znow", ",", 
        RowBox[{"1", "-", "p"}]}], "}"}]}], "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"znow", "=", 
