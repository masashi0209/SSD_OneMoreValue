Cell[BoxData[{
 RowBox[{
  RowBox[{"params", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Kp", "->", "K5"}], ",", 
     RowBox[{"n", "->", "SS"}], ",", 
     RowBox[{"sn", "->", "1"}], ",", 
     RowBox[{"kn", "->", 
      RowBox[{
       RowBox[{"Quantile", "[", 
        RowBox[{
         RowBox[{"NoncentralStudentTDistribution", "[", 
          RowBox[{
           RowBox[{"SS", "-", "1"}], ",", 
           RowBox[{
            RowBox[{"-", 
             RowBox[{"Sqrt", "[", "SS", "]"}]}], "K5"}]}], "]"}], ",", 
         "0.95"}], "]"}], "/", 
       RowBox[{"Sqrt", "[", "SS", "]"}]}]}], ",", "\[IndentingNewLine]", 
     RowBox[{"knn", "->", 
      RowBox[{
       RowBox[{"Quantile", "[", 
        RowBox[{
         RowBox[{"NoncentralStudentTDistribution", "[", 
          RowBox[{"SS", ",", 
           RowBox[{
            RowBox[{"-", 
             RowBox[{"Sqrt", "[", 
              RowBox[{"SS", "+", "1"}], "]"}]}], "K5"}]}], "]"}], ",", 
         "0.95"}], "]"}], "/", 
       RowBox[{"Sqrt", "[", 
        RowBox[{"SS", "+", "1"}], "]"}]}]}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"maxZ", "=", 
  RowBox[{"maxPNEC", "/.", "params"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"del", "=", "0.01"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"znow", "=", 
   RowBox[{"-", "3"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"myCDF", "=", 
   RowBox[{"{", "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Do", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"intRng", "=", 
     RowBox[{
      RowBox[{"solX", "/.", "params"}], "/.", 
      RowBox[{"z", "->", "znow"}]}]}], ";", "\[IndentingNewLine]", 
