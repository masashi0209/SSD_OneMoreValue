Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"NOECs", "=", 
  RowBox[{"Log10", "[", 
   RowBox[{"{", 
    RowBox[{
    "0.97", ",", "3.33", ",", "3.63", ",", "13.50", ",", "13.80", ",", 
     "18.70", ",", "154."}], "}"}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ya", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"k", "/", "8"}], ",", 
     RowBox[{"{", 
      RowBox[{"k", ",", "7"}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"m", "=", 
  RowBox[{"Mean", "[", "NOECs", "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"sd", "=", 
  RowBox[{"StandardDeviation", "[", "NOECs", "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ai", "=", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"CDF", "[", 
      RowBox[{
       RowBox[{"NormalDistribution", "[", 
        RowBox[{"m", ",", "sd"}], "]"}], ",", "x"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"-", "1"}], ",", "3"}], "}"}], ",", 
     RowBox[{"PlotStyle", "->", 
      RowBox[{"GrayLevel", "[", "0", "]"}]}], ",", 
     RowBox[{"AxesOrigin", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "1"}], ",", "0"}], "}"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"bi", "=", 
   RowBox[{"ListPlot", "[", 
    RowBox[{
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{"NOECs", ",", "ya"}], "}"}], "]"}], ",", 
     RowBox[{"PlotStyle", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"GrayLevel", "[", "0", "]"}], ",", 
        RowBox[{"PointSize", "[", "0.03", "]"}]}], "}"}]}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"Show", "[", 
  RowBox[{"ai", ",", "bi"}], "]"}]}], "Input",
