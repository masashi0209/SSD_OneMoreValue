Cell[CellGroupData[{

Cell["comparison with monte-carlo", "Subsection",
 CellChangeTimes->{{3.972688673108653*^9, 
  3.972688679010607*^9}},ExpressionUUID->"57254db9-bcbf-4c76-b59b-\
06e77da7f033"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"dAFs", "=", 
   RowBox[{"{", "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Do", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"preSample", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"RandomReal", "[", 
         RowBox[{"NormalDistribution", "[", 
          RowBox[{"0", ",", "3.14"}], "]"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"k", ",", "SS"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"preSd", "=", 
      RowBox[{"StandardDeviation", "[", "preSample", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"preAF", "=", 
      RowBox[{
       RowBox[{"preSd", 
        RowBox[{"(", 
         RowBox[{"Kp", "+", "kn"}], ")"}]}], "/.", "params"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"postSample", "=", 
      RowBox[{"AppendTo", "[", 
       RowBox[{"preSample", ",", 
        RowBox[{"RandomReal", "[", 
         RowBox[{"NormalDistribution", "[", 
          RowBox[{"0", ",", "3.14"}], "]"}], "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"postSd", "=", 
      RowBox[{"StandardDeviation", "[", "postSample", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"postAF", "=", 
      RowBox[{
       RowBox[{"postSd", 
        RowBox[{"(", 
         RowBox[{"Kp", "+", "knn"}], ")"}]}], "/.", "params"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"dAF", "=", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"postAF", "-", "preAF"}], ")"}], "/", "preSd"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"AppendTo", "[", 
      RowBox[{"dAFs", ",", "dAF"}], "]"}], ";"}], "\[IndentingNewLine]", ",", 
    
    RowBox[{"{", 
     RowBox[{"t", ",", "10000"}], "}"}]}], "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ci", "=", 
   RowBox[{"Histogram", "[", 
    RowBox[{"dAFs", ",", "200", ",", "\"\<CDF\>\""}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Show", "[", 
  RowBox[{"ci", ",", "grCDF", ",", 
   RowBox[{"PlotRange", "->", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "1"}], ",", "2"}], "}"}], ",", "All"}], "}"}]}], ",", 
   RowBox[{"AxesOrigin", "->", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"-", "1"}], ",", "0"}], "}"}]}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.9726887115255337`*^9, 3.972688822420253*^9}, 
