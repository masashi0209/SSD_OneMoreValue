Cell[BoxData[
 RowBox[{
  RowBox[{"Do", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"params", "=", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Kp", "->", "K5"}], ",", 
        RowBox[{"n", "->", 
         RowBox[{
          RowBox[{"sns", "[", 
           RowBox[{"[", "k", "]"}], "]"}], "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], ",", 
        RowBox[{"sn", "->", 
         RowBox[{
          RowBox[{"sns", "[", 
           RowBox[{"[", "k", "]"}], "]"}], "[", 
          RowBox[{"[", "2", "]"}], "]"}]}]}], "}"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"intRng", "=", 
      RowBox[{
       RowBox[{"solX", "/.", "params"}], "/.", 
       RowBox[{"z", "->", 
        RowBox[{"Log10", "[", "0.5", "]"}]}]}]}], ";", "\[IndentingNewLine]", 
     
     RowBox[{"p", "=", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"CDF", "[", 
         RowBox[{
          RowBox[{"StudentTDistribution", "[", 
           RowBox[{"SS", "-", "1"}], "]"}], ",", 
          RowBox[{"intRng", "[", 
           RowBox[{"[", "2", "]"}], "]"}]}], "]"}], "-", 
        RowBox[{"CDF", "[", 
         RowBox[{
          RowBox[{"StudentTDistribution", "[", 
           RowBox[{"SS", "-", "1"}], "]"}], ",", 
          RowBox[{"intRng", "[", 
           RowBox[{"[", "1", "]"}], "]"}]}], "]"}]}], ")"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<sample size = \>\"", ",", 
       RowBox[{
        RowBox[{"sns", "[", 
