Cell[CellGroupData[{

Cell["change in PNEC", "Section",
 CellChangeTimes->{{3.972690034464349*^9, 
  3.972690036662888*^9}},ExpressionUUID->"ffb89b4d-90d7-4f62-a71c-\
cb69ec06696d"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"SS", "=", "5"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"params", "=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"Kp", "->", "K5"}], ",", 
    RowBox[{"n", "->", "SS"}], ",", 
    RowBox[{"sn", "->", "1"}], ",", 
    RowBox[{"kn", "->", 
     RowBox[{
      RowBox[{"Quantile", "[", 
       RowBox[{
        RowBox[{"NoncentralStudentTDistribution", "[", 
         RowBox[{
          RowBox[{"SS", "-", "1"}], ",", 
          RowBox[{
           RowBox[{"-", 
            RowBox[{"Sqrt", "[", "SS", "]"}]}], "K5"}]}], "]"}], ",", 
        "0.95"}], "]"}], "/", 
      RowBox[{"Sqrt", "[", "SS", "]"}]}]}], ",", "\[IndentingNewLine]", 
    RowBox[{"knn", "->", 
     RowBox[{
      RowBox[{"Quantile", "[", 
       RowBox[{
        RowBox[{"NoncentralStudentTDistribution", "[", 
         RowBox[{"SS", ",", 
          RowBox[{
           RowBox[{"-", 
            RowBox[{"Sqrt", "[", 
             RowBox[{"SS", "+", "1"}], "]"}]}], "K5"}]}], "]"}], ",", 
        "0.95"}], "]"}], "/", 
      RowBox[{"Sqrt", "[", 
       RowBox[{"SS", "+", "1"}], "]"}]}]}]}], 
   "}"}]}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"DPNEC", "[", 
     RowBox[{"x", ",", "SS", ",", "Kp", ",", "sn", ",", "kn", ",", "knn"}], 
     "]"}], "/.", "params"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{"-", "2"}], ",", "2"}], "}"}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"solX", "=", 
  RowBox[{"x", "/.", 
   RowBox[{"Solve", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"DPNEC", "[", 
       RowBox[{"x", ",", "n", ",", "Kp", ",", "sn", ",", "kn", ",", "knn"}], 
       "]"}], "==", "z"}], ",", "x"}], "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{"maxX", "=", 
  RowBox[{"x", "/.", 
   RowBox[{"Simplify", "[", 
    RowBox[{
     RowBox[{"Solve", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"D", "[", 
         RowBox[{
          RowBox[{"DPNEC", "[", 
           RowBox[{
           "x", ",", "n", ",", "Kp", ",", "sn", ",", "kn", ",", "knn"}], 
           "]"}], ",", "x"}], "]"}], "==", "0"}], ",", "x"}], "]"}], "[", 
     RowBox[{"[", "2", "]"}], "]"}], "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"maxPNEC", "=", 
   RowBox[{"DPNEC", "[", 
    RowBox[{"maxX", ",", "n", ",", "Kp", ",", "sn", ",", "kn", ",", "knn"}], 
    "]"}]}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"Print", "[", "\"\<Probability that PNEC increases\>\"", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"intRng", "=", 
   RowBox[{
    RowBox[{"solX", "/.", "params"}], "/.", 
    RowBox[{"z", "->", "0"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"p", "=", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"CDF", "[", 
     RowBox[{
      RowBox[{"StudentTDistribution", "[", 
       RowBox[{"SS", "-", "1"}], "]"}], ",", 
      RowBox[{"intRng", "[", 
       RowBox[{"[", "2", "]"}], "]"}]}], "]"}], "-", 
    RowBox[{"CDF", "[", 
     RowBox[{
      RowBox[{"StudentTDistribution", "[", 
       RowBox[{"SS", "-", "1"}], "]"}], ",", 
      RowBox[{"intRng", "[", 
       RowBox[{"[", "1", "]"}], "]"}]}], "]"}]}], ")"}]}]}], "Input",
 CellChangeTimes->{{3.972690084747059*^9, 3.972690123598544*^9}, {
  3.972690172419626*^9, 3.9726902724833527`*^9}},
 CellLabel->
  "In[2693]:=",ExpressionUUID->"c9dcc854-b70e-41bf-a33f-7209a48942f9"],

