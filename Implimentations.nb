Cell[CellGroupData[{

Cell["intersections between curves and z (=log10(v))", "Subsection",
 CellChangeTimes->{{3.9726787569423656`*^9, 
  3.97267879566963*^9}},ExpressionUUID->"37c3e013-07da-416b-9786-\
7326ced8e6dd"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"solX", "=", 
  RowBox[{"Solve", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"S", "[", 
      RowBox[{"x", ",", "n"}], "]"}], "==", "z"}], ",", "x"}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"minSn", " ", "=", " ", 
  RowBox[{"S", "[", 
   RowBox[{"0", ",", "n"}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.966384057750997*^9, 3.9663841038985243`*^9}, {
