Cell[CellGroupData[{

Cell["dependencies of sn on the probability that postHC5 > preHC5", \
"Subsection",
 CellChangeTimes->{{3.9726831847031937`*^9, 
  3.972683203630022*^9}},ExpressionUUID->"f8663d8b-7822-4e8d-9fc1-\
254f1ae683c2"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"SS", "=", "5"}], ";"}], " "}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"params", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Kp", "->", "K5"}], ",", 
     RowBox[{"n", "->", "SS"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"del", "=", "0.001"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"minSn", " ", "=", " ", 
   RowBox[{"sn", "/.", 
    RowBox[{
     RowBox[{"Solve", "[", 
      RowBox[{
       RowBox[{"maxHC5", "==", "z"}], ",", "sn"}], "]"}], "[", 
     RowBox[{"[", "1", "]"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"vs", "=", 
   RowBox[{"Log10", "[", 
    RowBox[{"{", 
     RowBox[{"2", ",", "1.5", ",", "1", ",", "0.5", ",", "0.1", ",", "0.01"}],
      "}"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"mins", "=", 
   RowBox[{"{", "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Do", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"snnow", "=", 
      RowBox[{
       RowBox[{"minSn", "/.", "params"}], "/.", 
       RowBox[{"z", "->", 
        RowBox[{"vs", "[", 
         RowBox[{"[", "k", "]"}], "]"}]}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"snnow", "<", "0.01"}], ",", 
       RowBox[{"AppendTo", "[", 
        RowBox[{"mins", ",", "0.01"}], "]"}], ",", 
       RowBox[{"AppendTo", "[", 
        RowBox[{"mins", ",", "snnow"}], "]"}]}], "]"}], ";"}], 
    "\[IndentingNewLine]", ",", 
    RowBox[{"{", 
     RowBox[{"k", ",", 
      RowBox[{"Length", "[", "vs", "]"}]}], "}"}]}], "]"}], 
  ";"}], "\[IndentingNewLine]", "mins", "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"grs", "=", 
   RowBox[{"{", "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Do", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"snnow", "=", 
      RowBox[{"mins", "[", 
       RowBox[{"[", "k", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"dHC5s", "=", 
      RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Do", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"snnow", ">", "2.0"}], ",", 
          RowBox[{"Break", "[", "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"intRng", "=", 
         RowBox[{
          RowBox[{
           RowBox[{"solX", "/.", "params"}], "/.", 
           RowBox[{"z", "->", 
            RowBox[{"vs", "[", 
             RowBox[{"[", "k", "]"}], "]"}]}]}], "/.", 
          RowBox[{"sn", "->", "snnow"}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"p", "=", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"CDF", "[", 
            RowBox[{
             RowBox[{"StudentTDistribution", "[", 
              RowBox[{"SS", "-", "1"}], "]"}], ",", 
             RowBox[{"intRng", "[", 
              RowBox[{"[", "2", "]"}], "]"}]}], "]"}], "-", 
           RowBox[{"CDF", "[", 
            RowBox[{
             RowBox[{"StudentTDistribution", "[", 
              RowBox[{"SS", "-", "1"}], "]"}], ",", 
             RowBox[{"intRng", "[", 
              RowBox[{"[", "1", "]"}], "]"}]}], "]"}]}], ")"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"AppendTo", "[", 
         RowBox[{"dHC5s", ",", 
          RowBox[{"{", 
           RowBox[{"snnow", ",", "p"}], "}"}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"snnow", "=", 
         RowBox[{"snnow", "+", "del"}]}], ";"}], "\[IndentingNewLine]", ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "10000"}], "}"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Length", "[", "dHC5s", "]"}], ">", "0"}], ",", 
       RowBox[{"AppendTo", "[", 
        RowBox[{"grs", ",", "dHC5s"}], "]"}]}], "]"}], ";"}], 
    "\[IndentingNewLine]", ",", 
    RowBox[{"{", 
     RowBox[{"k", ",", 
      RowBox[{"Length", "[", "vs", "]"}]}], "}"}]}], "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"ListPlot", "[", 
  RowBox[{"grs", ",", 
   RowBox[{"Joined", "->", "True"}], ",", 
   RowBox[{"AspectRatio", "->", "1"}], ",", 
   RowBox[{"Frame", "->", "True"}], ",", 
   RowBox[{"PlotRange", "->", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"0", ",", "2"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"0", ",", "1"}], "}"}]}], "}"}]}]}], 
  "]"}], "\[IndentingNewLine]"}], "Input",
