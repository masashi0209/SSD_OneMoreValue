Cell[BoxData[
 RowBox[{"(*", " ", 
  RowBox[{
   RowBox[{
   "Take", " ", "3", " ", "NOECs", " ", "from", " ", "the", " ", "original", " ",
     "datase"}], ",", " ", 
   RowBox[{"and", " ", "add", " ", "one"}]}], "*)"}]], "Input",
 CellChangeTimes->{{3.972698100449627*^9, 3.9726981171410637`*^9}, 
   3.9726997150907917`*^9},ExpressionUUID->"099eaefb-3559-4f98-9c7c-\
23a68bb1426e"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"SS", "=", "4"}], ";"}], " "}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"params", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Kp", "->", "K5"}], ",", 
     RowBox[{"n", "->", "SS"}], ",", 
     RowBox[{"kn", "->", 
      RowBox[{
       RowBox[{"Quantile", "[", 
        RowBox[{
         RowBox[{"NoncentralStudentTDistribution", "[", 
          RowBox[{
           RowBox[{"SS", "-", "1"}], ",", 
           RowBox[{
            RowBox[{"-", 
             RowBox[{"Sqrt", "[", "SS", "]"}]}], "K5"}]}], "]"}], ",", 
         "0.95"}], "]"}], "/", 
       RowBox[{"Sqrt", "[", "SS", "]"}]}]}], ",", "\[IndentingNewLine]", 
     RowBox[{"knn", "->", 
      RowBox[{
       RowBox[{"Quantile", "[", 
        RowBox[{
         RowBox[{"NoncentralStudentTDistribution", "[", 
          RowBox[{"SS", ",", 
           RowBox[{
            RowBox[{"-", 
             RowBox[{"Sqrt", "[", 
              RowBox[{"SS", "+", "1"}], "]"}]}], "K5"}]}], "]"}], ",", 
         "0.95"}], "]"}], "/", 
       RowBox[{"Sqrt", "[", 
        RowBox[{"SS", "+", "1"}], "]"}]}]}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"dNOECs", " ", "=", " ", 
   RowBox[{"{", "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Do", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"sLst", "=", 
      RowBox[{"IntegerDigits", "[", 
       RowBox[{"k", ",", "2", ",", "7"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"num", "=", 
      RowBox[{"uvec", ".", "sLst"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"num", "==", "SS"}], ",", 
       RowBox[{"{", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"sNOECs", "=", 
          RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"nNOECs", "=", 
          RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"Do", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"sLst", "[", 
                RowBox[{"[", "t", "]"}], "]"}], "==", "1"}], ",", 
              RowBox[{"AppendTo", "[", 
               RowBox[{"sNOECs", ",", 
                RowBox[{"NOECs", "[", 
                 RowBox[{"[", "t", "]"}], "]"}]}], "]"}], ",", 
              RowBox[{"AppendTo", "[", 
               RowBox[{"nNOECs", ",", 
                RowBox[{"NOECs", "[", 
                 RowBox[{"[", "t", "]"}], "]"}]}], "]"}]}], "]"}], ";"}], 
           "\[IndentingNewLine]", ",", 
           RowBox[{"{", 
            RowBox[{"t", ",", "7"}], "}"}]}], "]"}], ";", 
         "\[IndentingNewLine]", "\[IndentingNewLine]", 
         RowBox[{"preMean", "=", 
          RowBox[{"Mean", "[", "sNOECs", "]"}]}], ";", "\[IndentingNewLine]", 
         
         RowBox[{"preSD", "=", 
          RowBox[{"StandardDeviation", "[", "sNOECs", "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"preNOEC", " ", "=", " ", 
          RowBox[{"preMean", "-", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"kn", "/.", "params"}], ")"}], "preSD"}]}]}], ";", 
         "\[IndentingNewLine]", "\[IndentingNewLine]", 
         RowBox[{"Do", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{
            RowBox[{"aNOECS", "=", 
             RowBox[{"Flatten", "[", 
              RowBox[{"{", 
               RowBox[{"sNOECs", ",", 
                RowBox[{"nNOECs", "[", 
                 RowBox[{"[", "j", "]"}], "]"}]}], "}"}], "]"}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"postMean", "=", 
             RowBox[{"Mean", "[", "aNOECS", "]"}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"postSD", "=", 
             RowBox[{"StandardDeviation", "[", "aNOECS", "]"}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"postNOEC", " ", "=", " ", 
             RowBox[{"postMean", "-", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"knn", "/.", "params"}], ")"}], "postSD"}]}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"AppendTo", "[", 
             RowBox[{"dNOECs", ",", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"postNOEC", "-", "preNOEC"}], ")"}], "/", "preSD"}]}],
              "]"}], ";"}], "\[IndentingNewLine]", ",", 
           RowBox[{"{", 
            RowBox[{"j", ",", 
             RowBox[{"7", "-", "SS"}]}], "}"}]}], "]"}], ";"}], 
        "\[IndentingNewLine]", "}"}]}], "]"}], ";"}], "\[IndentingNewLine]", ",", 
    RowBox[{"{", 
     RowBox[{"k", ",", "1", ",", "tnum"}], "}"}]}], "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"grHist", "=", 
  RowBox[{"Histogram", "[", 
   RowBox[{"dNOECs", ",", "20", ",", "\"\<CDF\>\"", ",", 
    RowBox[{"PlotRange", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "3"}], ",", "2"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"0", ",", "1"}], "}"}]}], "}"}]}], ",", 
    RowBox[{"AxesOrigin", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "3"}], ",", "0"}], "}"}]}], ",", 
    RowBox[{"Frame", "->", "True"}], ",", 
    RowBox[{"ChartStyle", "->", 
     RowBox[{"GrayLevel", "[", "0.8", "]"}]}]}], "]"}]}]}], "Input",
