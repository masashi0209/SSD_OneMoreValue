Cell[CellGroupData[{

Cell["comparison with monte-carlo", "Subsection",
 CellChangeTimes->{
  3.972690535095907*^9},ExpressionUUID->"52678d39-1a26-44cf-9333-\
8bceef6a2f80"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"dPNECs", "=", 
   RowBox[{"{", "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Do", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"preSample", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"RandomReal", "[", 
         RowBox[{"NormalDistribution", "[", 
          RowBox[{"0", ",", "3.14"}], "]"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"k", ",", "SS"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"preMean", "=", 
      RowBox[{"Mean", "[", "preSample", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"preSd", "=", 
      RowBox[{"StandardDeviation", "[", "preSample", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"preNOEC", "=", 
      RowBox[{"preMean", "-", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"kn", " ", "preSd"}], "/.", "params"}], ")"}]}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"postSample", "=", 
      RowBox[{"AppendTo", "[", 
       RowBox[{"preSample", ",", 
        RowBox[{"RandomReal", "[", 
         RowBox[{"NormalDistribution", "[", 
          RowBox[{"0", ",", "3.14"}], "]"}], "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"postMean", "=", 
      RowBox[{"Mean", "[", "postSample", "]"}]}], ";", "\[IndentingNewLine]", 
     
     RowBox[{"postSd", "=", 
      RowBox[{"StandardDeviation", "[", "postSample", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"postNOEC", "=", 
      RowBox[{"postMean", "-", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"knn", " ", "postSd"}], "/.", "params"}], ")"}]}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"dPNEC", "=", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"postNOEC", "-", "preNOEC"}], ")"}], "/", "preSd"}]}], ";", 
