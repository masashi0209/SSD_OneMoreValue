Cell["comparison with monte-carlo", "Subsection",
 CellChangeTimes->{{3.972679694881843*^9, 
  3.9726797062493687`*^9}},ExpressionUUID->"7217ccd5-95b2-4ad3-9d30-\
7558bb6c80c0"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"snRatios", "=", 
   RowBox[{"{", "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Do", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"preSample", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"RandomReal", "[", 
         RowBox[{"NormalDistribution", "[", 
          RowBox[{"0", ",", "3.14"}], "]"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"k", ",", "10"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"preSd", "=", 
      RowBox[{"StandardDeviation", "[", "preSample", "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"postSample", "=", 
      RowBox[{"AppendTo", "[", 
       RowBox[{"preSample", ",", 
        RowBox[{"RandomReal", "[", 
         RowBox[{"NormalDistribution", "[", 
          RowBox[{"0", ",", "3.14"}], "]"}], "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"postSd", "=", 
      RowBox[{"StandardDeviation", "[", "postSample", "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"sRatio", "=", 
      RowBox[{"postSd", "/", "preSd"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"AppendTo", "[", 
      RowBox[{"snRatios", ",", "sRatio"}], "]"}], ";"}], 
    "\[IndentingNewLine]", ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "10000"}], "}"}]}], "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ci", "=", 
   RowBox[{"Histogram", "[", 
    RowBox[{"snRatios", ",", "100", ",", "\"\<CDF\>\""}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"di", "=", 
