   RowBox[{"-", 
    FractionBox[
     RowBox[{
      RowBox[{
       SqrtBox[
        RowBox[{"n", " ", 
         RowBox[{"(", 
          RowBox[{"1", "+", "n"}], ")"}]}]], " ", "sn", " ", 
