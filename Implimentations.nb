Cell[CellGroupData[{

Cell["\<\
dependencies of sn on the probability that postPNEC > v prePNEC\
\>", "Subsection",
 CellChangeTimes->{{3.972692124645776*^9, 
  3.97269215136909*^9}},ExpressionUUID->"fcba99f2-a87d-4b0e-a157-\
f72b5459fd89"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"SS", "=", "5"}], ";"}], " "}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"params", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Kp", "->", "K5"}], ",", 
     RowBox[{"n", "->", "SS"}], ",", 
     RowBox[{"kn", "->", 
      RowBox[{
       RowBox[{"Quantile", "[", 
        RowBox[{
         RowBox[{"NoncentralStudentTDistribution", "[", 
          RowBox[{
           RowBox[{"SS", "-", "1"}], ",", 
           RowBox[{
            RowBox[{"-", 
             RowBox[{"Sqrt", "[", "SS", "]"}]}], "K5"}]}], "]"}], ",", 
         "0.95"}], "]"}], "/", 
       RowBox[{"Sqrt", "[", "SS", "]"}]}]}], ",", "\[IndentingNewLine]", 
     RowBox[{"knn", "->", 
      RowBox[{
       RowBox[{"Quantile", "[", 
        RowBox[{
         RowBox[{"NoncentralStudentTDistribution", "[", 
          RowBox[{"SS", ",", 
           RowBox[{
            RowBox[{"-", 
             RowBox[{"Sqrt", "[", 
              RowBox[{"SS", "+", "1"}], "]"}]}], "K5"}]}], "]"}], ",", 
         "0.95"}], "]"}], "/", 
       RowBox[{"Sqrt", "[", 
        RowBox[{"SS", "+", "1"}], "]"}]}]}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"del", "=", "0.01"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"minSn", " ", "=", " ", 
   RowBox[{"sn", "/.", 
    RowBox[{
     RowBox[{"Solve", "[", 
      RowBox[{
       RowBox[{"maxPNEC", "==", "z"}], ",", "sn"}], "]"}], "[", 
     RowBox[{"[", "1", "]"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"snnow", "=", 
    RowBox[{
     RowBox[{"minSn", "/.", "params"}], "/.", 
     RowBox[{"z", "->", 
      RowBox[{"vs", "[", 
       RowBox[{"[", "2", "]"}], "]"}]}]}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"vs", "=", 
    RowBox[{"Log10", "[", 
     RowBox[{"{", 
      RowBox[{
      "50", ",", "10", ",", "5", ",", "2", ",", "1.5", ",", "1", ",", "0.5", ",",
        "0.1", ",", "0.01", ",", "0.01"}], "}"}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"mins", "=", 
   RowBox[{"{", "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Do", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"snnow", "=", 
      RowBox[{
       RowBox[{"minSn", "/.", "params"}], "/.", 
       RowBox[{"z", "->", 
        RowBox[{"vs", "[", 
         RowBox[{"[", "k", "]"}], "]"}]}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"snnow", "<", "0.01"}], ",", 
       RowBox[{"AppendTo", "[", 
        RowBox[{"mins", ",", "0.01"}], "]"}], ",", 
       RowBox[{"AppendTo", "[", 
        RowBox[{"mins", ",", "snnow"}], "]"}]}], "]"}], ";"}], 
    "\[IndentingNewLine]", ",", 
    RowBox[{"{", 
     RowBox[{"k", ",", 
      RowBox[{"Length", "[", "vs", "]"}]}], "}"}]}], "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"grs", "=", 
   RowBox[{"{", "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Do", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"snnow", "=", 
      RowBox[{"mins", "[", 
       RowBox[{"[", "k", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"dPNECs", "=", 
      RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Do", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"snnow", ">", "2.0"}], ",", 
          RowBox[{"Break", "[", "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"intRng", "=", 
         RowBox[{
          RowBox[{
           RowBox[{"solX", "/.", "params"}], "/.", 
           RowBox[{"z", "->", 
            RowBox[{"vs", "[", 
             RowBox[{"[", "k", "]"}], "]"}]}]}], "/.", 
          RowBox[{"sn", "->", "snnow"}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"p", "=", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"CDF", "[", 
            RowBox[{
             RowBox[{"StudentTDistribution", "[", 
              RowBox[{"SS", "-", "1"}], "]"}], ",", 
             RowBox[{"intRng", "[", 
              RowBox[{"[", "2", "]"}], "]"}]}], "]"}], "-", 
           RowBox[{"CDF", "[", 
            RowBox[{
             RowBox[{"StudentTDistribution", "[", 
              RowBox[{"SS", "-", "1"}], "]"}], ",", 
             RowBox[{"intRng", "[", 
              RowBox[{"[", "1", "]"}], "]"}]}], "]"}]}], ")"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"AppendTo", "[", 
         RowBox[{"dPNECs", ",", 
          RowBox[{"{", 
           RowBox[{"snnow", ",", "p"}], "}"}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"snnow", "=", 
         RowBox[{"snnow", "+", "del"}]}], ";"}], "\[IndentingNewLine]", ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "10000"}], "}"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Length", "[", "dPNECs", "]"}], ">", "0"}], ",", 
       RowBox[{"AppendTo", "[", 
        RowBox[{"grs", ",", "dPNECs"}], "]"}]}], "]"}], ";"}], 
    "\[IndentingNewLine]", ",", 
    RowBox[{"{", 
     RowBox[{"k", ",", 
      RowBox[{"Length", "[", "vs", "]"}]}], "}"}]}], "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"ListPlot", "[", 
