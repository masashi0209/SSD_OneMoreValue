c2b07d83678c"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"dHC5s", "=", 
   RowBox[{"{", "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Do", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"preSample", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"RandomReal", "[", 
         RowBox[{"NormalDistribution", "[", 
          RowBox[{"0", ",", "3.14"}], "]"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"k", ",", "SS"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"preSd", "=", 
      RowBox[{"StandardDeviation", "[", "preSample", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"preMean", "=", 
      RowBox[{"Mean", "[", "preSample", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"preHC5", " ", "=", " ", 
      RowBox[{"preMean", "+", 
       RowBox[{"K5", " ", "preSd"}]}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"postSample", "=", 
      RowBox[{"AppendTo", "[", 
       RowBox[{"preSample", ",", 
        RowBox[{"RandomReal", "[", 
         RowBox[{"NormalDistribution", "[", 
          RowBox[{"0", ",", "3.14"}], "]"}], "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"postSd", "=", 
      RowBox[{"StandardDeviation", "[", "postSample", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"postMean", "=", 
      RowBox[{"Mean", "[", "postSample", "]"}]}], ";", "\[IndentingNewLine]", 
     
     RowBox[{"postHC5", " ", "=", " ", 
      RowBox[{"postMean", "+", 
       RowBox[{"K5", " ", "postSd"}]}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"dHC5", "=", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"postHC5", "-", "preHC5"}], ")"}], "/", "preSd"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"AppendTo", "[", 
      RowBox[{"dHC5s", ",", "dHC5"}], "]"}], ";"}], "\[IndentingNewLine]", ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "10000"}], "}"}]}], "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ci", "=", 
   RowBox[{"Histogram", "[", 
    RowBox[{"dHC5s", ",", "500", ",", "\"\<CDF\>\""}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"di", "=", 
   RowBox[{"Histogram", "[", 
    RowBox[{"dHC5s", ",", "500", ",", "\"\<PDF\>\""}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Show", "[", 
  RowBox[{"ci", ",", "grCDF"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"Show", "[", 
  RowBox[{"di", ",", "grPDF"}], "]"}]}], "Input",
