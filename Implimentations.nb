Cell[CellGroupData[{

Cell["\<\
obtaining the probability that post-HC5 > v pre-HC5 (z = log10(v)). n=5, v = \
2, sn=1.5 as example\
\>", "Subsection",
 CellChangeTimes->{{3.9726799400573797`*^9, 3.9726799930495358`*^9}, {
  3.972680251749157*^9, 3.9726802820817842`*^9}, {3.9726804019815474`*^9, 
  3.972680402265135*^9}},ExpressionUUID->"6e64bcd6-3ddb-4b9b-afcb-\
16cb9322107c"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"solX", "=", 
  RowBox[{"FullSimplify", "[", 
   RowBox[{"x", "/.", 
    RowBox[{"Solve", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"DHC5", "[", 
        RowBox[{"x", ",", "n", ",", "Kp", ",", "sn"}], "]"}], "==", "z"}], ",",
       "x"}], "]"}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"maxX", "=", 
  RowBox[{"FullSimplify", "[", 
   RowBox[{"x", "/.", 
    RowBox[{
     RowBox[{"Solve", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"D", "[", 
         RowBox[{
          RowBox[{"DHC5", "[", 
           RowBox[{"x", ",", "n", ",", "Kp", ",", "sn"}], "]"}], ",", "x"}], 
         "]"}], "==", "0"}], ",", "x"}], "]"}], "[", 
     RowBox[{"[", "2", "]"}], "]"}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"maxHC5", "=", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{"DHC5", "[", 
     RowBox[{"maxX", ",", "n", ",", "Kp", ",", "sn"}], "]"}], "]"}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"SS", "=", "5"}], ";"}], " "}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"params", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Kp", "->", "K5"}], ",", 
     RowBox[{"n", "->", "SS"}], ",", 
     RowBox[{"sn", "->", "1.5"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"If", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{"maxHC5", "/.", "params"}], ")"}], "<", 
    RowBox[{"Log10", "[", "2", "]"}]}], ",", 
   RowBox[{"Print", "[", "\"\<No solution\>\"", "]"}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"intRng", "=", 
   RowBox[{
    RowBox[{"solX", "/.", "params"}], "/.", 
    RowBox[{"z", "->", 
     RowBox[{"Log10", "[", "2", "]"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Print", "[", "\"\<Probability that post-HC5 > 2 pre-HC5\>\"", 
  "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"(", 
   RowBox[{
    RowBox[{"CDF", "[", 
     RowBox[{
      RowBox[{"StudentTDistribution", "[", 
       RowBox[{"SS", "-", "1"}], "]"}], ",", 
      RowBox[{"intRng", "[", 
       RowBox[{"[", "2", "]"}], "]"}]}], "]"}], "-", 
    RowBox[{"CDF", "[", 
     RowBox[{
      RowBox[{"StudentTDistribution", "[", 
       RowBox[{"SS", "-", "1"}], "]"}], ",", 
      RowBox[{"intRng", "[", 
       RowBox[{"[", "1", "]"}], "]"}]}], "]"}]}], ")"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]"}], "Input",
 CellChangeTimes->{{3.969421539470005*^9, 3.969421541734323*^9}, {
