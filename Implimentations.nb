Cell[CellGroupData[{

Cell["Values of sn for which P(post-HC5 <\.bd\[Times] or >2\[Times] pre-HC5) \
= 0.05", "Section",
 CellChangeTimes->{
  3.9726924958843117`*^9},ExpressionUUID->"e5a9b388-7fe6-4968-bd7c-\
30329ffee9ac"],

Cell["\<\
This involves finding the intersection of the wavy line and the curve in the \
diagram below.
Blue lines is for postHC5 > 2 preHC5, and orange line is for postHC5 > 1/2 \
preHC5.
As is clear from the figure,  sn for postHC5 > 1/2 preHC5 is lower, so we \
consider only this case.\
\>", "Text",
 CellChangeTimes->{{3.972695340894436*^9, 3.972695420999978*^9}, {
  3.9726955258749647`*^9, 3.972695528417272*^9}, {3.972695569262027*^9, 
  3.972695579640305*^9}},ExpressionUUID->"49f146ff-a5ad-42f3-afe2-\
346f55b47361"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"SS", "=", "5"}], ";"}], " "}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"solX", "=", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{"x", "/.", 
     RowBox[{"Solve", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"DHC5", "[", 
         RowBox[{"x", ",", "n", ",", "Kp", ",", "sn"}], "]"}], "==", "z"}], ",",
        "x"}], "]"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"maxX", "=", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{"x", "/.", 
     RowBox[{
      RowBox[{"Solve", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"D", "[", 
          RowBox[{
           RowBox[{"DHC5", "[", 
            RowBox[{"x", ",", "n", ",", "Kp", ",", "sn"}], "]"}], ",", "x"}], 
          "]"}], "==", "0"}], ",", "x"}], "]"}], "[", 
      RowBox[{"[", "2", "]"}], "]"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"maxHC5", "=", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{"DHC5", "[", 
     RowBox[{"maxX", ",", "n", ",", "Kp", ",", "sn"}], "]"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"params", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Kp", "->", "K5"}], ",", 
     RowBox[{"n", "->", "SS"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"del", "=", "0.001"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"minSn", " ", "=", " ", 
   RowBox[{"sn", "/.", 
    RowBox[{
     RowBox[{"Solve", "[", 
      RowBox[{
       RowBox[{"maxHC5", "==", "z"}], ",", "sn"}], "]"}], "[", 
     RowBox[{"[", "1", "]"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"vs", "=", 
   RowBox[{"Log10", "[", 
    RowBox[{"{", 
     RowBox[{"2", ",", "0.5"}], "}"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"mins", "=", 
   RowBox[{"{", "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Do", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"snnow", "=", 
      RowBox[{
       RowBox[{"minSn", "/.", "params"}], "/.", 
       RowBox[{"z", "->", 
        RowBox[{"vs", "[", 
         RowBox[{"[", "k", "]"}], "]"}]}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"snnow", "<", "0.01"}], ",", 
       RowBox[{"AppendTo", "[", 
        RowBox[{"mins", ",", "0.01"}], "]"}], ",", 
       RowBox[{"AppendTo", "[", 
        RowBox[{"mins", ",", "snnow"}], "]"}]}], "]"}], ";"}], 
    "\[IndentingNewLine]", ",", 
    RowBox[{"{", 
     RowBox[{"k", ",", 
      RowBox[{"Length", "[", "vs", "]"}]}], "}"}]}], "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"grs", "=", 
   RowBox[{"{", "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Do", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"snnow", "=", 
      RowBox[{"mins", "[", 
       RowBox[{"[", "k", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"dHC5s", "=", 
      RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Do", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"snnow", ">", "2.0"}], ",", 
          RowBox[{"Break", "[", "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"intRng", "=", 
         RowBox[{
          RowBox[{
           RowBox[{"solX", "/.", "params"}], "/.", 
           RowBox[{"z", "->", 
            RowBox[{"vs", "[", 
             RowBox[{"[", "k", "]"}], "]"}]}]}], "/.", 
          RowBox[{"sn", "->", "snnow"}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"p", "=", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"CDF", "[", 
            RowBox[{
             RowBox[{"StudentTDistribution", "[", 
              RowBox[{"SS", "-", "1"}], "]"}], ",", 
             RowBox[{"intRng", "[", 
              RowBox[{"[", "2", "]"}], "]"}]}], "]"}], "-", 
           RowBox[{"CDF", "[", 
            RowBox[{
             RowBox[{"StudentTDistribution", "[", 
              RowBox[{"SS", "-", "1"}], "]"}], ",", 
             RowBox[{"intRng", "[", 
              RowBox[{"[", "1", "]"}], "]"}]}], "]"}]}], ")"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"AppendTo", "[", 
         RowBox[{"dHC5s", ",", 
          RowBox[{"{", 
           RowBox[{"snnow", ",", "p"}], "}"}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"snnow", "=", 
         RowBox[{"snnow", "+", "del"}]}], ";"}], "\[IndentingNewLine]", ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "10000"}], "}"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Length", "[", "dHC5s", "]"}], ">", "0"}], ",", 
       RowBox[{"AppendTo", "[", 
        RowBox[{"grs", ",", "dHC5s"}], "]"}]}], "]"}], ";"}], 
    "\[IndentingNewLine]", ",", 
    RowBox[{"{", 
     RowBox[{"k", ",", 
      RowBox[{"Length", "[", "vs", "]"}]}], "}"}]}], "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ai", "=", 
   RowBox[{"ListPlot", "[", 
    RowBox[{"grs", ",", 
     RowBox[{"Joined", "->", "True"}], ",", 
     RowBox[{"AspectRatio", "->", "1"}], ",", 
     RowBox[{"Frame", "->", "True"}], ",", 
     RowBox[{"PlotRange", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"0", ",", "2"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"0", ",", "1"}], "}"}]}], "}"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"bi", "=", 
   RowBox[{"Plot", "[", 
    RowBox[{"0.95", ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "0", ",", "2.0"}], "}"}], ",", 
     RowBox[{"PlotStyle", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Dashing", "[", 
         RowBox[{"{", 
          RowBox[{"0.01", ",", "0.01"}], "}"}], "]"}], ",", 
        RowBox[{"GrayLevel", "[", "0", "]"}]}], "}"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ci", "=", 
   RowBox[{"Plot", "[", 
    RowBox[{"0.05", ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "0", ",", "2.0"}], "}"}], ",", 
     RowBox[{"PlotStyle", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Dashing", "[", 
         RowBox[{"{", 
          RowBox[{"0.01", ",", "0.01"}], "}"}], "]"}], ",", 
        RowBox[{"GrayLevel", "[", "0", "]"}]}], "}"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Show", "[", 
  RowBox[{"ai", ",", "bi", ",", "ci"}], 
  "]"}], "\[IndentingNewLine]"}], "Input",
 CellChangeTimes->{{3.972695215224373*^9, 3.972695291553588*^9}, {
  3.9726953506616287`*^9, 3.972695351058099*^9}, {3.972697438389879*^9, 
  3.97269744258818*^9}},
 CellLabel->
  "In[2747]:=",ExpressionUUID->"51c79397-4e73-4738-afe6-0edf4f4e83e6"],

