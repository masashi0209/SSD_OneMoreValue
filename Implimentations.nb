Cell["Define a function to calculate the probability for any sn", "Text",
 CellChangeTimes->{
  3.9726954856957006`*^9},ExpressionUUID->"8f7f155b-fc04-4d6d-8900-\
54db59f92416"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"pCalc05", "[", 
    RowBox[{
    "solX_", ",", "params_", ",", "maxHC5_", ",", "snv_", ",", "val_"}], 
    "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "p", "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"intRng", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"solX", "/.", "params"}], "/.", 
         RowBox[{"z", "->", 
          RowBox[{"Log10", "[", "val", "]"}]}]}], "/.", 
        RowBox[{"sn", "->", "snv"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"p", "=", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"CDF", "[", 
          RowBox[{
           RowBox[{"StudentTDistribution", "[", 
            RowBox[{"SS", "-", "1"}], "]"}], ",", 
           RowBox[{"intRng", "[", 
            RowBox[{"[", "2", "]"}], "]"}]}], "]"}], "-", 
         RowBox[{"CDF", "[", 
          RowBox[{
           RowBox[{"StudentTDistribution", "[", 
            RowBox[{"SS", "-", "1"}], "]"}], ",", 
           RowBox[{"intRng", "[", 
            RowBox[{"[", "1", "]"}], "]"}]}], "]"}]}], ")"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Return", "[", "p", "]"}], ";"}]}], "\[IndentingNewLine]", 
    "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.97269298277055*^9, 3.972693253228348*^9}, {
   3.972693313872321*^9, 3.972693315605247*^9}, 3.9726936277529*^9},
 CellLabel->
  "In[2763]:=",ExpressionUUID->"327efb3a-132c-4556-aa86-4def6ebbd85d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Pr", "[", 
     RowBox[{"postHC5", ">", 
      RowBox[{
       RowBox[{"1", "/", "2"}], " ", "preHC5"}]}], "]"}], " ", "=", " ", 
    RowBox[{
     RowBox[{"0.05", ":", " ", 
      RowBox[{"Pr", "[", 
       RowBox[{"postHC5", " ", "<", " ", 
        RowBox[{
         RowBox[{"1", "/", "2"}], " ", "preHC5"}]}], "]"}]}], " ", "=", " ", 
     "0.95"}]}], "  ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"newton", " ", "method"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"del", " ", "=", " ", "0.0001"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"sns", "=", 
     RowBox[{"{", "}"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Do", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"params", "=", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Kp", "->", "K5"}], ",", 
          RowBox[{"n", "->", "k"}]}], "}"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"snnow", " ", "=", "1."}], ";", "\[IndentingNewLine]", 
       RowBox[{"Do", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"FNow", " ", "=", " ", 
           RowBox[{
            RowBox[{"pCalc05", "[", 
             RowBox[{
             "solX", ",", "params", ",", "maxHC5", ",", "snnow", ",", "0.5"}],
              "]"}], "-", "0.95"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"FAft", " ", "=", " ", 
           RowBox[{
            RowBox[{"pCalc05", "[", 
             RowBox[{"solX", ",", "params", ",", "maxHC5", ",", 
              RowBox[{"snnow", "+", "del"}], ",", "0.5"}], "]"}], "-", 
            "0.95"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"Abs", "[", "FNow", "]"}], "<", "0.0000001"}], ",", 
            RowBox[{"Break", "[", "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
          
          RowBox[{"grad", " ", "=", " ", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"FAft", "-", "FNow"}], ")"}], "/", "del"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"snnow", " ", "=", " ", 
           RowBox[{"snnow", "-", 
            RowBox[{"0.01", 
             RowBox[{"FNow", "/", "grad"}]}]}]}], ";"}], 
         "\[IndentingNewLine]", ",", 
         RowBox[{"{", 
          RowBox[{"t", ",", "10000"}], "}"}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"AppendTo", "[", 
        RowBox[{"sns", ",", 
         RowBox[{"{", 
          RowBox[{"k", ",", "snnow"}], "}"}]}], "]"}], ";"}], 
      "\[IndentingNewLine]", ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", "3", ",", "30"}], "}"}]}], "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"ListPlot", "[", 
    RowBox[{"sns", ",", 
     RowBox[{"PlotStyle", "->", 
      RowBox[{"{", 
       RowBox[{"GrayLevel", "[", "0", "]"}], "}"}]}], ",", 
     RowBox[{"Frame", "->", "True"}], ",", 
     RowBox[{"PlotRange", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"2", ",", "31"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"0", ",", "2"}], "}"}]}], "}"}]}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.972693163551415*^9, 3.972693262860853*^9}, {
