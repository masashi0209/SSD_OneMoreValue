Notebook[{
Cell[BoxData[{
 RowBox[{
  RowBox[{"S", "[", 
   RowBox[{"x_", ",", "n_"}], "]"}], ":=", 
  RowBox[{"Sqrt", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"n", "-", "1"}], ")"}], "/", "n"}], "+", 
    RowBox[{"x", " ", 
     RowBox[{"x", "/", "n"}]}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"DHC5", "[", 
   RowBox[{"x_", ",", "n_", ",", "Kp_", ",", "sn_"}], "]"}], ":=", 
  RowBox[{"sn", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      RowBox[{"1", "/", 
       RowBox[{"Sqrt", "[", 
        RowBox[{"n", 
         RowBox[{"(", 
          RowBox[{"n", "+", "1"}], ")"}]}], "]"}]}], "x"}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"S", "[", 
         RowBox[{"x", ",", "n"}], "]"}], "-", "1"}], ")"}], "Kp"}]}], 
    ")"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"DAF", "[", 
   RowBox[{"x_", ",", "n_", ",", "Kp_", ",", "sn_", ",", "kn_", ",", "knn_"}],
    "]"}], ":=", 
  RowBox[{"sn", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      RowBox[{"S", "[", 
       RowBox[{"x", ",", "n"}], "]"}], 
      RowBox[{"(", 
       RowBox[{"Kp", "+", "knn"}], ")"}]}], "-", 
     RowBox[{"(", 
      RowBox[{"Kp", "+", "kn"}], ")"}]}], ")"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"DPNEC", "[", 
   RowBox[{"x_", ",", "n_", ",", "Kp_", ",", "sn_", ",", "kn_", ",", "knn_"}],
    "]"}], ":=", 
  RowBox[{
   RowBox[{"DHC5", "[", 
    RowBox[{"x", ",", "n", ",", "Kp", ",", "sn"}], "]"}], "-", 
   RowBox[{"DAF", "[", 
    RowBox[{"x", ",", "n", ",", "Kp", ",", "sn", ",", "kn", ",", "knn"}], 
    "]"}]}]}]}], "Input",
