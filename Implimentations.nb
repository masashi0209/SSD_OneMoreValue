Cell[CellGroupData[{

Cell["CDF", "Subsection",
 CellChangeTimes->{{3.9726882051390047`*^9, 
  3.972688205467093*^9}},ExpressionUUID->"c91a6dad-c7db-4b9e-bd15-\
593fc3783c99"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"params", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Kp", "->", "K5"}], ",", 
     RowBox[{"n", "->", "SS"}], ",", 
     RowBox[{"sn", "->", "1"}], ",", 
     RowBox[{"kn", "->", 
      RowBox[{
       RowBox[{"Quantile", "[", 
        RowBox[{
         RowBox[{"NoncentralStudentTDistribution", "[", 
          RowBox[{
           RowBox[{"SS", "-", "1"}], ",", 
           RowBox[{
            RowBox[{"-", 
             RowBox[{"Sqrt", "[", "SS", "]"}]}], "K5"}]}], "]"}], ",", 
         "0.95"}], "]"}], "/", 
       RowBox[{"Sqrt", "[", "SS", "]"}]}]}], ",", "\[IndentingNewLine]", 
     RowBox[{"knn", "->", 
      RowBox[{
       RowBox[{"Quantile", "[", 
        RowBox[{
         RowBox[{"NoncentralStudentTDistribution", "[", 
          RowBox[{"SS", ",", 
           RowBox[{
            RowBox[{"-", 
             RowBox[{"Sqrt", "[", 
              RowBox[{"SS", "+", "1"}], "]"}]}], "K5"}]}], "]"}], ",", 
         "0.95"}], "]"}], "/", 
       RowBox[{"Sqrt", "[", 
        RowBox[{"SS", "+", "1"}], "]"}]}]}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"del", "=", "0.01"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"AFnow", "=", 
  RowBox[{"minAF", "/.", "params"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"myCDF", "=", 
   RowBox[{"{", 
    RowBox[{"{", 
     RowBox[{"AFnow", ",", "0"}], "}"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Do", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"AFnow", "=", 
      RowBox[{"AFnow", "+", "del"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"AFnow", ">", "2"}], ",", 
       RowBox[{"Break", "[", "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"intRng", "=", 
      RowBox[{
       RowBox[{"solX", "/.", "params"}], "/.", 
       RowBox[{"z", "->", "AFnow"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"p", "=", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"CDF", "[", 
         RowBox[{
          RowBox[{"StudentTDistribution", "[", 
           RowBox[{"SS", "-", "1"}], "]"}], ",", 
          RowBox[{"intRng", "[", 
           RowBox[{"[", "2", "]"}], "]"}]}], "]"}], "-", 
        RowBox[{"CDF", "[", 
         RowBox[{
          RowBox[{"StudentTDistribution", "[", 
           RowBox[{"SS", "-", "1"}], "]"}], ",", 
          RowBox[{"intRng", "[", 
           RowBox[{"[", "1", "]"}], "]"}]}], "]"}]}], ")"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"AppendTo", "[", 
      RowBox[{"myCDF", ",", 
       RowBox[{"{", 
        RowBox[{"AFnow", ",", "p"}], "}"}]}], "]"}], ";"}], 
    "\[IndentingNewLine]", ",", 
    RowBox[{"{", 
     RowBox[{"k", ",", "100000"}], "}"}]}], "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"grCDF", "=", 
  RowBox[{"ListPlot", "[", 
   RowBox[{"myCDF", ",", 
    RowBox[{"Joined", "->", "True"}], ",", 
    RowBox[{"PlotRange", "->", "All"}], ",", 
    RowBox[{"AxesOrigin", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "1"}], ",", "0"}], "}"}]}]}], "]"}]}]}], "Input",
