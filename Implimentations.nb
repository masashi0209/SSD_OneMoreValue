Cell["\<\
CDF of delta log HC5, sn=1, n=5 as example ( probabilities that post-HC5 is \
lower than pre-HC5)\
\>", "Subsection",
 CellChangeTimes->{{3.972680188544626*^9, 3.972680194577951*^9}, {
  3.972681054151416*^9, 3.972681063039033*^9}, {3.972683107769353*^9, 
  3.9726831285264606`*^9}},ExpressionUUID->"52e24859-e40d-411a-b9f3-\
05126f2a0560"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"SS", "=", "5"}], ";"}], " "}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"params", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Kp", "->", "K5"}], ",", 
     RowBox[{"n", "->", "SS"}], ",", 
     RowBox[{"sn", "->", "1"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"maxZ", "=", 
   RowBox[{"maxHC5", "/.", "params"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"del", "=", "0.01"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"znow", "=", 
   RowBox[{"-", "3"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"myCDF", "=", 
   RowBox[{"{", "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Do", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"intRng", "=", 
     RowBox[{
      RowBox[{"solX", "/.", "params"}], "/.", 
      RowBox[{"z", "->", "znow"}]}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"znow", ">", "maxZ"}], ",", 
      RowBox[{"Break", "[", "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"p", "=", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"CDF", "[", 
        RowBox[{
         RowBox[{"StudentTDistribution", "[", 
          RowBox[{"SS", "-", "1"}], "]"}], ",", 
         RowBox[{"intRng", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], "]"}], "-", 
       RowBox[{"CDF", "[", 
        RowBox[{
         RowBox[{"StudentTDistribution", "[", 
          RowBox[{"SS", "-", "1"}], "]"}], ",", 
         RowBox[{"intRng", "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], "]"}]}], ")"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"AppendTo", "[", 
     RowBox[{"myCDF", ",", 
      RowBox[{"{", 
       RowBox[{"znow", ",", 
        RowBox[{"1", "-", "p"}]}], "}"}]}], "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"znow", "=", 
     RowBox[{"znow", "+", "del"}]}], ";"}], "\[IndentingNewLine]", ",", 
   RowBox[{"{", 
    RowBox[{"k", ",", "100000"}], "}"}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"myCDF", "=", 
   RowBox[{"AppendTo", "[", 
    RowBox[{"myCDF", ",", 
     RowBox[{"{", 
      RowBox[{"maxZ", ",", "1"}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"grCDF", "=", 
  RowBox[{"ListPlot", "[", 
   RowBox[{"myCDF", ",", 
    RowBox[{"Joined", "->", "True"}], ",", 
    RowBox[{"PlotRange", "->", "All"}], ",", 
    RowBox[{"AxesOrigin", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "3"}], ",", "0"}], "}"}]}]}], 
   "]"}]}], "\[IndentingNewLine]"}], "Input",
